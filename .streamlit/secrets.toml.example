# Configuración de Secrets para Streamlit Cloud
# Copia este archivo a .streamlit/secrets.toml en Streamlit Cloud

# Opción 1 (recomendada): Connection string directa de Supabase.
# IMPORTANTE: usa la URI exacta de Supabase en Settings > Database > Connection string.
# DATABASE_URL = "postgresql://postgres:TU_PASSWORD_DB@db.bytakahnzqticzmdmxdm.supabase.co:5432/postgres"

# Opción 2: Host + password de BD (sin exponer la URI completa)
SUPABASE_URL = "https://bytakahnzqticzmdmxdm.supabase.co"
SUPABASE_DB_PASSWORD = "TU_PASSWORD_DB"

# Nota: SUPABASE_KEY / ANON key es para API REST/Auth, NO para conexión PostgreSQL.
# También puedes agregar otras variables si es necesario
# OPENAI_API_KEY = "sk-..."